{
  "name": "@bz/sentry",
  "version": "0.1.0-next.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:js": "bun build src/index.ts --outdir dist --target browser --format esm --sourcemap=linked && bun build src/server.ts --outdir dist --target node --format esm --sourcemap=linked",
    "build:types": "tsc --project tsconfig.json",
    "build": "bun run clean && bun run build:js && bun run build:types",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "echo \"No tests\""
  },
  "dependencies": {
    "@sentry/solid": "^10.22.0",
    "@sentry/browser": "^7.14.0",
    "@sentry/node": "^7.14.0",
    "@sentry/tracing": "^7.14.0"
  },
  "devDependencies": {
    "typescript": "^5.1.0"
  }
}
